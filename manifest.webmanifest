{
  "name": "WeatherScope",
  "short_name": "WeatherScope",
  "description": "A responsive weather dashboard with forecasts, AQI, UV index, maps, favorites, and location search.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#f5f7ff",
